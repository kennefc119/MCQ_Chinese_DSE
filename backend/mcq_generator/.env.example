# Poe API  (poe.com → 右上角 → Settings → API Key)
POE_API_KEY=your_poe_api_key_here

# ── Bot configuration ──────────────────────────────────────────────────────────
# Default bot — used as fallback when a role-specific bot is not set.
# Any bot name you have access to on Poe works here, e.g.:
#   Claude-3.7-Sonnet  /  Claude-3-Haiku  /  GPT-4o  /  Gemini-2.0-Flash
POE_BOT_NAME=Claude-3.7-Sonnet

# Per-role bot overrides (comment out to use POE_BOT_NAME as fallback)
# Role 1 — Strategist: decides which passage/skill/difficulty to target next.
#   Recommended: a fast, cheap model (reads stats, outputs a small JSON spec).
POE_BOT_STRATEGIST=Claude-3-Haiku

# Role 2 — Drafter: writes the actual MC question + 4 options + explanations.
#   Recommended: best reasoning model available (most creative & domain-accurate).
POE_BOT_DRAFTER=Claude-3.7-Sonnet

# Role 3 — Critic: reviews the draft and scores it; requests revisions if needed.
#   Recommended: a strong but cheaper model; low temperature is set in code (0.3).
POE_BOT_CRITIC=Claude-3.7-Sonnet

# Supabase (使用 service_role key 才能繞過 RLS 直接寫入)
# Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://njqoigiwbljygmqkqtby.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# 執行控制
MAX_CYCLES_PER_RUN=50
MAX_REVISE_ITERATIONS=3
SLEEP_BETWEEN_CYCLES_SECONDS=1
DEFAULT_SOURCE_TAG=agent-v2

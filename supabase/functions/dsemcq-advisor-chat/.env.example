# Supabase Edge Function — dsemcq-advisor-chat
# Copy to .env (gitignored) or set in Supabase Dashboard → Edge Functions → Secrets

# Get your key at https://poe.com/api_key
POE_API_KEY=your_poe_api_key_here

# Which Poe bot to call (default: Claude-3-Sonnet)
# Other options: GPT-4o, Claude-3-Opus, Llama-3-70b-Groq, etc.
POE_BOT_NAME=Claude-3-Sonnet

# Auto-injected by Supabase — do NOT set manually
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
